---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'daily' | 'weekly' | 'monthly' | 'archive';
}

const { title, description, activeNav } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <script is:inline>
    // 从 localStorage 读取主题，避免闪烁
    (function () {
      var saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') {
        document.documentElement.dataset.theme = saved;
      }
    })();
  </script>
</head>
<body>

<!-- ─────────── top bar ─────────── -->
<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand">
      <span class="brand-mark">G</span>
      <span>GoodGithub</span>
      <span class="brand-cn">好仓</span>
    </a>

    <nav class="nav-tabs">
      <a href="/" class={activeNav === 'daily' ? 'active' : undefined}>今日</a>
      <a href="/weekly" class={activeNav === 'weekly' ? 'active' : undefined}>本周</a>
      <a href="/monthly" class={activeNav === 'monthly' ? 'active' : undefined}>本月</a>
      <a href="/archive" class={activeNav === 'archive' ? 'active' : undefined}>历史</a>
    </nav>

    <div class="search">
      <svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
      <input placeholder="搜索项目名 / 中文摘要 …" aria-label="搜索" />
      <kbd>⌘K</kbd>
    </div>

    <div class="topbar-right">
      <!-- 语言筛选占位 -->
      <button class="pill" title="语言筛选" disabled>
        <span class="lang-dot" style="background:#3178c6"></span>
        全部语言
        <svg class="i caret" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>

      <!-- 日期占位 -->
      <button class="pill" title="选择日期" disabled>
        <svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        <span id="js-date">—</span>
      </button>

      <!-- 主题切换 -->
      <button class="icon-btn" id="theme-toggle" title="切换主题" aria-label="切换主题">
        <svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- 汉堡菜单（移动端，JS 抽屉待 W2 实现） -->
      <button class="icon-btn hamburger" aria-label="菜单">
        <svg class="i" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- ─────────── main content ─────────── -->
<slot />

<script is:inline>
  // 日期显示
  (function () {
    var el = document.getElementById('js-date');
    if (el) {
      var d = new Date();
      el.textContent = d.getFullYear() + '-'
        + String(d.getMonth() + 1).padStart(2, '0') + '-'
        + String(d.getDate()).padStart(2, '0');
    }
  })();

  // 主题切换
  document.getElementById('theme-toggle').addEventListener('click', function () {
    var html = document.documentElement;
    var next = html.dataset.theme === 'light' ? 'dark' : 'light';
    html.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

</body>
</html>

<style>
  /* ─────────── top bar ─────────── */
  .topbar {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .topbar-inner {
    max-width: 1440px; margin: 0 auto;
    display: flex; align-items: center; gap: 24px;
    padding: 12px 28px;
  }
  .brand {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-en); font-weight: 600; font-size: 16px; letter-spacing: -0.01em;
    color: var(--fg);
    text-decoration: none;
  }
  .brand:hover { text-decoration: none; }
  .brand-mark {
    width: 26px; height: 26px; border-radius: 6px;
    background: linear-gradient(135deg, #1f6feb 0%, #58a6ff 100%);
    display: grid; place-items: center;
    color: white; font-weight: 800; font-size: 13px;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.06) inset;
    flex-shrink: 0;
  }
  .brand-cn { color: var(--muted); font-family: var(--font-cn); font-weight: 400; font-size: 12px; margin-left: 2px; }

  .nav-tabs { display: flex; align-items: center; gap: 2px; }
  .nav-tabs a {
    color: var(--fg-2); padding: 6px 12px; border-radius: 6px;
    font-size: 14px; font-weight: 500;
    text-decoration: none;
  }
  .nav-tabs a:hover { background: var(--surface); text-decoration: none; }
  .nav-tabs a.active { color: var(--fg); background: var(--surface); }
  .nav-tabs a.active::after {
    content: ""; display: block; height: 2px; margin: 6px -12px -8px;
    background: var(--accent);
  }

  .search {
    flex: 1; max-width: 380px; position: relative;
  }
  .search input {
    width: 100%; background: var(--surface); border: 1px solid var(--border);
    color: var(--fg); padding: 7px 12px 7px 34px; border-radius: 6px;
    font-family: var(--font-cn); font-size: 13px; outline: none;
  }
  .search input::placeholder { color: var(--muted-2); }
  .search input:focus { border-color: var(--accent); }
  .search svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--muted); }
  .search kbd {
    position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
    font-family: var(--font-mono); font-size: 11px; color: var(--muted);
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
    padding: 1px 5px;
  }

  .topbar-right { display: flex; align-items: center; gap: 8px; margin-left: auto; }

  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--fg-2); padding: 6px 10px; border-radius: 6px;
    font-size: 13px; font-family: inherit;
  }
  .pill:not(:disabled):hover { background: var(--elev); border-color: var(--muted-2); }
  .pill:disabled { cursor: default; }
  .pill .caret { color: var(--muted); }
  .lang-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

  .icon-btn {
    width: 32px; height: 32px; border-radius: 6px;
    display: grid; place-items: center;
    background: transparent; border: 1px solid transparent;
    color: var(--muted);
  }
  .icon-btn:hover { background: var(--surface); color: var(--fg); border-color: var(--border); }

  .i { width: 14px; height: 14px; stroke-width: 1.7; }

  /* 汉堡：桌面隐藏 */
  .hamburger { display: none; }

  /* ─────────── 响应式 ─────────── */
  @media (max-width: 768px) {
    .nav-tabs { display: none; }
    .search { display: none; }
    .pill { display: none; }
    .hamburger { display: grid; }
    .topbar-inner { gap: 12px; padding: 10px 16px; }
  }
</style>
